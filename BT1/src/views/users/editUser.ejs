<!DOCTYPE html>
<html>
<head>
    <title>Chỉnh sửa người dùng</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.0/dist/css/bootstrap.min.css">
    <style>
        .edit-container { max-width: 600px; margin: 50px auto; padding: 30px; background: white; box-shadow: 0 0 10px rgba(0,0,0,0.1); border-radius: 8px; }
        .btn-update { width: 100%; font-weight: bold; }
    </style>
</head>
<body class="bg-light">
    <div class="edit-container">
        <h3 class="text-center mb-4">Cập nhật thông tin</h3>
        <form action="/put-crud" method="POST">
            <input type="text" name="id" value="<%= data.id %>" hidden>

            <div class="form-row">
                <div class="form-group col-md-6">
                    <label>First Name</label>
                    <input type="text" class="form-control" name="firstName" value="<%= data.firstName %>" required>
                </div>
                <div class="form-group col-md-6">
                    <label>Last Name</label>
                    <input type="text" class="form-control" name="lastName" value="<%= data.lastName %>" required>
                </div>
            </div>

            <div class="form-group">
                <label>Address</label>
                <input type="text" class="form-control" name="address" value="<%= data.address %>" required>
            </div>

            <button type="submit" class="btn btn-primary btn-update">Lưu thay đổi</button>
            <a href="/get-crud" class="btn btn-link btn-block">Hủy bỏ</a>
        </form>
    </div>
</body>
</html>