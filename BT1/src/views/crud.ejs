<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.0/dist/css/bootstrap.min.css">
    <style>
        body { background-color: #f4f7f9; font-family: 'Roboto', sans-serif; }
        .form-card { max-width: 650px; margin: 50px auto; background: white; padding: 40px; 
                     border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); border-top: 5px solid #007bff; }
        .form-header { text-align: center; margin-bottom: 30px; }
        .form-header h2 { font-weight: 700; color: #333; }
        .label-custom { font-weight: 600; color: #555; }
        .form-control { border-radius: 8px; padding: 12px; border: 1px solid #ddd; }
        .form-control:focus { box-shadow: 0 0 8px rgba(0,123,255,0.25); border-color: #007bff; }
        .btn-submit { background: #007bff; border: none; padding: 12px; border-radius: 8px; 
                      font-weight: 600; font-size: 16px; margin-top: 20px; transition: 0.3s; }
        .btn-submit:hover { background: #0056b3; transform: scale(1.02); }
        .btn-back { display: block; text-align: center; margin-top: 15px; color: #666; }
    </style>
</head>
<form action="/post-crud" method="post">

    <div class="form-row">
        <div class="form-group col-md-6">
            <label for="inputEmail4">Email</label>
            <input type="email" class="form-control" id="email" name="email">
        </div>
        <div class="form-group col-md-6">
            <label for="inputPassword4">Password</label>
            <input type="password" class="form-control" id="password" name="password">
        </div>
    </div>

    <div class="form-row">
        <div class="form-group col-md-6">
            <label for="inputEmail4">First Name</label>
            <input type="text" class="form-control" id="firstName" name="firstName">
        </div>
        <div class="form-group col-md-6">
            <label for="inputPassword4">Last Name</label>
            <input type="text" class="form-control" id="lastName" name="lastName">
        </div>
    </div>

    <div class="form-row">
        <div class="form-group col-md-4">
            <label for="inputCity">Phone Number</label>
            <input type="text" class="form-control" id="phoneNumber" name="phoneNumber">
        </div>
        <div class="form-group col-md-4">
            <label for="inputState">Gender</label>
            <select id="gender" name="gender" class="form-control">
                <option selected value="0">Male</option>
                <option value="1">Female</option>
            </select>
        </div>
        <div class="form-group col-md-4">
            <label for="role">Role</label>
            <select id="roleId" name="roleId" class="form-control">
                <option selected value="1">Admin</option>
                <option value="2">Doctor</option>
                <option value="3">Patient</option>
            </select>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Thêm</button>
</form>